#!/usr/bin/env bash
set -euo pipefail

# vLLM serving wrapper - activates flox environment and runs vllm serve
# Usage: vllm-serve [model] [additional vllm args...]

FLOX_ENV="/home/saren/projects/dotfiles/packages/flox/global-env/.flox/run/x86_64-linux.global-env.run"
CUDA_LIB_DIR="$HOME/.local/share/flox-cuda-lib"

export PATH="$FLOX_ENV/bin:$FLOX_ENV/sbin:$PATH"
if [ -d "$CUDA_LIB_DIR" ]; then
  export LD_LIBRARY_PATH="${CUDA_LIB_DIR}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

exec vllm serve "$@"
