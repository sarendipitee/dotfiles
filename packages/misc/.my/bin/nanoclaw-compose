#!/usr/bin/env bash
# Bootstrap and run a per-user NanoClaw + OneCLI stack.  All mutable state
# lives below ~/.local/share/nanoclaw; no system-wide files are created.
set -euo pipefail

USER_NAME=$(id -un)
HOME_DIR=$(getent passwd "$(id -u)" | cut -d: -f6)
ROOT=${NANOCLAW_ROOT:-$HOME_DIR/.local/share/nanoclaw}
UID_NUM=${HOST_UID:-$(id -u)}
GID_NUM=${HOST_GID:-$(id -g)}
DOCKER_GID=${HOST_DOCKER_GID:-$(stat -c '%g' /var/run/docker.sock)}
PORT_SEED=$((UID_NUM % 10000))
APP_PORT=${ONECLI_APP_PORT:-$((20000 + PORT_SEED))}
GATEWAY_PORT=${ONECLI_GATEWAY_PORT:-$((30000 + PORT_SEED))}
REPO_REF=${NANOCLAW_REF:-v2.1.17}
LOCAL_VLLM_URL=${LOCAL_VLLM_URL:-http://127.0.0.1:8080/v1}
LOCAL_VLLM_CONTAINER_URL=${LOCAL_VLLM_CONTAINER_URL:-http://host.docker.internal:8080/v1}

set_env_line() {
  local file=$1 key=$2 value=$3
  if grep -q "^${key}=" "$file" 2>/dev/null; then sed -i "s|^${key}=.*|${key}=${value}|" "$file"; else printf '%s=%s\n' "$key" "$value" >> "$file"; fi
}

detect_local_model() {
  python3 - "$LOCAL_VLLM_URL/models" <<'PY'
import json, sys, urllib.request
with urllib.request.urlopen(sys.argv[1], timeout=5) as response:
    models = json.load(response).get("data") or []
if not models: raise SystemExit("no models returned")
print(models[0]["id"])
PY
}

LOCAL_MODEL_ID=$(detect_local_model) || { echo "could not reach local vLLM at $LOCAL_VLLM_URL/models" >&2; exit 1; }
mkdir -p "$ROOT"
if [ ! -d "$ROOT/.git" ]; then
  [ -z "$(find "$ROOT" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ] || { echo "refusing to clone into non-empty $ROOT" >&2; exit 1; }
  git clone --depth 1 --branch "$REPO_REF" https://github.com/nanocoai/nanoclaw.git "$ROOT"
fi

mkdir -p "$ROOT"/{.stack/postgres,.stack/onecli-data,data,groups,home,logs,store}
chmod 0777 "$ROOT/.stack/onecli-data"
: > "$ROOT/.env"
set_env_line "$ROOT/.env" ONECLI_URL http://onecli:10254
set_env_line "$ROOT/.env" TZ UTC
set_env_line "$ROOT/.env" OPENCODE_PROVIDER "${OPENCODE_PROVIDER:-openai}"
set_env_line "$ROOT/.env" OPENCODE_MODEL "${OPENCODE_MODEL:-openai/$LOCAL_MODEL_ID}"
set_env_line "$ROOT/.env" OPENCODE_SMALL_MODEL "${OPENCODE_SMALL_MODEL:-openai/$LOCAL_MODEL_ID}"
set_env_line "$ROOT/.env" ANTHROPIC_BASE_URL "${ANTHROPIC_BASE_URL:-$LOCAL_VLLM_CONTAINER_URL}"

export USER="$USER_NAME" HOME="$HOME_DIR" NANOCLAW_ROOT="$ROOT" HOST_UID="$UID_NUM" HOST_GID="$GID_NUM" HOST_DOCKER_GID="$DOCKER_GID" ONECLI_APP_PORT="$APP_PORT" ONECLI_GATEWAY_PORT="$GATEWAY_PORT"
cd "$ROOT"
exec docker compose "$@"
