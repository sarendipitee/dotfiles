{
	"$schema": "https://app.kilo.ai/config.json",
	"instructions": [
		"~/.config/agents/AGENTS.md"
	],
	"skills": {
		"paths": [
			"~/.claude/skills"
		]
	},
	"default_agent": "overseer",
	"permission": {
		"read": "ask",
		"edit": "ask",
		"glob": "allow",
		"grep": "allow",
		"list": "allow",
		"bash": {
			"*": "ask",
			"git checkout*": "deny",
			"git restore*": "deny",
			"git revert*": "deny",
			"git reset --hard*": "deny",
			"git reset -h*": "deny",
			"git clean*": "deny",
			"git stash drop*": "deny",
			"git push --force*": "deny",
			"git push -f *": "deny",
			"git push --force-with-lease*": "deny",
			"git rebase*": "deny",
			"git cherry-pick*": "deny",
			"git reflog*": "deny",
			"git filter-branch*": "deny",
			"git filter-repo*": "deny",
			"git submodule deinit*": "deny",
			"git status *": "allow",
			"git diff *": "allow",
			"ls *": "allow",
			"cat *": "allow",
			"moon *": "allow",
		},
		"task": "allow",
		"skill": "allow",
		"external_directory": {
			"/tmp/*": "allow",
			"/private/tmp/*": "allow",
			"~/.claude/*": "allow"
		}
	},
	"mcp": {
		"grafana": {
			"type": "local",
			"command": [
				"uvx",
				"mcp-grafana"
			],
			"environment": {
				"GRAFANA_URL": "$GRAFANA_URL",
				"GRAFANA_USERNAME": "$GRAFANA_USERNAME",
				"GRAFANA_PASSWORD": "$GRAFANA_PASSWORD"
			},
			"enabled": true
		}
	},
	"compaction": {
		"auto": true,
		"prune": true
	},
	"agent": {
		"explore": {
			"disable": true
		},
		"orchestrator": {
			"disable": true
		},
		"general": {
			"disable": true
		}
	},
	"provider": {
		"openai": {
			"models": {
				"gpt-5.3-codex-spark": {
					"limit": {
						"output": 16000,
						"context": 128000
					}
				}
			}
		}
	},
	"experimental": {
		"batch_tool": true
	}
}
