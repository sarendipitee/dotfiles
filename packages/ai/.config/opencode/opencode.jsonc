{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"vllm": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "vLLM (local)",
			"options": {
				"baseURL": "http://localhost:8080/v1"
			},
			"models": {
				"local": {
					"name": "cur local",
					"limit": {
						"context": 55000,
						"output": 8192
					}
				},
			}
		}
	},
	"instructions": [],
	"mcp": {
		"notion": {
			"type": "remote",
			"url": "https://mcp.notion.com/mcp",
			"enabled": false
		},
		"mcp-agent-mail": {
			"type": "remote",
			"url": "http://127.0.0.1:8765/mcp/",
			"enabled": false
		}
	},
	"skills": {
		"paths": []
	},
	"permission": {
		"read": "allow",
		"edit": {
			"*": "allow",
			"/etc/**": "ask",
			"/System/**": "ask",
			"/private/**": "ask",
			"/bin/**": "ask",
			"/sbin/**": "ask",
			"/usr/bin/**": "ask",
			"/usr/lib/**": "ask",
			"/dev/**": "ask",
			"/cores/**": "ask",
			"/boot/**": "ask",
			"/lib/**": "ask",
			"/lib64/**": "ask",
			"/proc/**": "ask",
			"/sys/**": "ask",
			"/root/**": "ask",
			"/run/**": "ask"
		},
		"glob": "allow",
		"grep": "allow",
		"list": "allow",
		"webfetch": "allow",
		"websearch": "allow",
		"external_directory": "allow",
		"bash": {
			"*": "allow",
			"sudo *": "ask",
			"rm -rf *": "ask",
			"rm -fr *": "ask",
			"chmod -R *": "ask",
			"chown -R *": "ask",
			"dd *": "ask",
			"mkfs*": "ask",
			"fdisk *": "ask",
			"parted *": "ask",
			"shutdown*": "ask",
			"reboot*": "ask",
			"halt*": "ask",
			"poweroff*": "ask",
			"killall *": "ask",
			"pkill *": "ask"
		}
	}
}
