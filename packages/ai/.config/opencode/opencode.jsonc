{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"zai-coding-plan": {
			"options": {
				"apiKey": "$ZAI_API_KEY"
			}
		}
	},
	"instructions": [
		"~/.config/agents/AGENTS.md"
	],
	"mcp": {
		"notion": {
			"type": "remote",
			"url": "https://mcp.notion.com/mcp",
			"enabled": true
		}
	}
}
