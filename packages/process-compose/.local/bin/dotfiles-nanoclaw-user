#!/usr/bin/env bash

set -euo pipefail

CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}
UNIT=dotfiles-process-compose.service
DROP_IN_DIR="$CONFIG_HOME/systemd/user/${UNIT}.d"
DROP_IN="$DROP_IN_DIR/20-nanoclaw.conf"
MISE_BIN="$HOME/.local/bin/mise"
NANOCLAW_MISE_CONFIG="$CONFIG_HOME/nanoclaw/mise.toml"

fail() {
	printf 'dotfiles-nanoclaw-user: %s\n' "$*" >&2
	exit 1
}

export PATH="$HOME/.local/bin:$PATH"

[[ $(id -u) -ne 0 ]] || fail 'must run as the NanoClaw owner, not root'
[[ -x "$MISE_BIN" ]] || fail "mise is missing: $MISE_BIN"
[[ -f "$NANOCLAW_MISE_CONFIG" ]] || fail "missing $NANOCLAW_MISE_CONFIG; copy the NanoClaw profile first"

case "${1:-enable}" in
	enable)
		loginctl enable-linger "$(id -un)"
		systemctl --user cat "$UNIT" >/dev/null ||
			fail "missing $UNIT; stow the process-compose and systemd packages first"
		mkdir -p "$DROP_IN_DIR"
		cat > "$DROP_IN" <<'EOF'
[Service]
Environment=DOTFILES_HOST=nanoclaw
Environment=MISE_CONFIG_FILE=%h/.config/nanoclaw/mise.toml
Environment=OPENCODE_PROVIDER=openai
Environment=OPENCODE_MODEL=openai/local
Environment=OPENCODE_SMALL_MODEL=openai/local
Environment=ANTHROPIC_BASE_URL=http://host.docker.internal:8080/v1
EOF
		MISE_CONFIG_FILE="$NANOCLAW_MISE_CONFIG" "$MISE_BIN" install
		systemctl --user daemon-reload
		systemctl --user enable "$UNIT"
		systemctl --user restart "$UNIT"
		;;
	disable)
		rm -f "$DROP_IN"
		systemctl --user daemon-reload
		systemctl --user disable --now "$UNIT"
		;;
	*)
		fail 'usage: dotfiles-nanoclaw-user [enable|disable]'
		;;
esac
