#!/usr/bin/env bash

set -euo pipefail

fatal() {
  printf 'dotfiles-codex-remote-control: %s\n' "$*" >&2
  exit 1
}

path_owner_uid() {
  local path="$1"
  local owner_uid
  if owner_uid=$(stat -f '%u' "$path" 2>/dev/null); then
    printf '%s\n' "$owner_uid"
  else
    stat -c '%u' "$path"
  fi
}

path_mode() {
  local path="$1"
  local mode
  if mode=$(stat -f '%Lp' "$path" 2>/dev/null); then
    printf '%s\n' "$mode"
  else
    stat -c '%a' "$path"
  fi
}

validate_ancestors() {
  local path="$1"
  local current_path=/
  local mode
  local owner_uid
  local path_suffix=${path#/}

  owner_uid=$(path_owner_uid /) || fatal 'cannot inspect root ownership'
  [[ "$owner_uid" == 0 ]] || fatal 'root has unexpected owner'
  mode=$(path_mode /) || fatal 'cannot inspect root permissions'
  (( (8#$mode & 8#022) == 0 )) || fatal 'root is group- or world-writable'
  while [[ -n "$path_suffix" ]]; do
    current_path="${current_path%/}/${path_suffix%%/*}"
    [[ -e "$current_path" ]] || fatal 'environment path contains missing component'
    [[ ! -L "$current_path" ]] || fatal 'environment path contains symlink'
    owner_uid=$(path_owner_uid "$current_path") || fatal 'cannot inspect environment path ownership'
    [[ "$owner_uid" == 0 || "$owner_uid" == "$login_uid" ]] ||
      fatal 'environment path contains foreign-owned component'
    mode=$(path_mode "$current_path") || fatal 'cannot inspect environment path permissions'
    (( (8#$mode & 8#022) == 0 )) || fatal 'environment path contains writable ancestor'
    [[ "$path_suffix" == "${path_suffix#*/}" ]] && break
    path_suffix=${path_suffix#*/}
  done
}

[[ "$HOME" == /* ]] || fatal 'HOME must be absolute'
[[ "$(realpath "$HOME")" == "$HOME" ]] || fatal 'HOME must be canonical non-symlink path'
mise_bin="$HOME/.local/bin/mise"
env_file="$HOME/.config/hindsight/hindsight.env"
login_uid=$(id -u)

[[ -x "$mise_bin" ]] || fatal "Mise executable missing: $mise_bin"
[[ -f "$env_file" && ! -L "$env_file" ]] || fatal 'Hindsight environment must be regular non-symlink file'
validate_ancestors "$env_file"
[[ "$(path_owner_uid "$env_file")" == "$login_uid" ]] || fatal 'Hindsight environment has wrong owner'
mode=$(path_mode "$env_file") || fatal 'cannot inspect Hindsight environment permissions'
(( (8#$mode & 8#7177) == 0 )) || fatal 'Hindsight environment permissions exceed 0600'

api_key=$("$mise_bin" exec -- python - "$env_file" "$login_uid" <<'PY'
import os
import re
import stat
import sys

path, expected_uid = sys.argv[1], int(sys.argv[2])
flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
try:
    descriptor = os.open(path, flags)
except OSError:
    raise SystemExit("cannot safely open Hindsight environment")
try:
    metadata = os.fstat(descriptor)
    if not stat.S_ISREG(metadata.st_mode) or metadata.st_uid != expected_uid:
        raise SystemExit("Hindsight environment changed during validation")
    if metadata.st_mode & 0o7177:
        raise SystemExit("Hindsight environment permissions exceed 0600")
    chunks = []
    remaining = 1_048_577
    while remaining:
        chunk = os.read(descriptor, remaining)
        if not chunk:
            break
        chunks.append(chunk)
        remaining -= len(chunk)
    content = b"".join(chunks)
finally:
    os.close(descriptor)

if len(content) > 1_048_576:
    raise SystemExit("Hindsight environment exceeds size limit")

matches = []
for line in content.split(b"\n"):
    if line.startswith(b"OMNIROUTER_API_KEY="):
        matches.append(line.removeprefix(b"OMNIROUTER_API_KEY="))
    elif re.match(rb"^[ \t]*(?:export[ \t]+)?OMNIROUTER_API_KEY[ \t]*", line):
        raise SystemExit("malformed OMNIROUTER_API_KEY entry")

if len(matches) == 0:
    raise SystemExit("OMNIROUTER_API_KEY entry missing")
if len(matches) > 1:
    raise SystemExit("duplicate OMNIROUTER_API_KEY entry")
key = matches[0]
if not key:
    raise SystemExit("OMNIROUTER_API_KEY entry empty")
if any(byte < 32 or byte == 127 for byte in key):
    raise SystemExit("OMNIROUTER_API_KEY contains control character")
os.write(sys.stdout.fileno(), key)
PY
)

export OMNIROUTER_API_KEY="$api_key"
unset api_key
exec "$mise_bin" exec -- codex remote-control --json
